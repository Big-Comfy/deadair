{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "deadair — telemetry health",
  "uid": "deadair-telemetry-health",
  "tags": ["deadair", "security", "detection-engineering"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "type": "stat",
      "title": "Scan health",
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "deadair_up", "legendFormat": "up" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "FAILING", "color": "red" }, "1": { "text": "OK", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Dead detections",
      "gridPos": { "h": 5, "w": 5, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "deadair_detections_dead", "legendFormat": "dead" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Unmapped detections",
      "gridPos": { "h": 5, "w": 5, "x": 9, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "deadair_detections_unmapped", "legendFormat": "unmapped" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }] }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Unused telemetry (ingest paid, never read)",
      "gridPos": { "h": 5, "w": 10, "x": 14, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "deadair_unused_telemetry_bytes", "legendFormat": "bytes" }],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10737418240 }] }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Sources by status",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "deadair_sources", "legendFormat": "{{status}}" }],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "ok" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "stale" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] },
          { "matcher": { "id": "byName", "options": "empty" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] },
          { "matcher": { "id": "byName", "options": "unknown" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "gray" } }] },
          { "matcher": { "id": "byName", "options": "maintenance" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }] }
        ]
      }
    },
    {
      "type": "timeseries",
      "title": "Stalest sources (top 10)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "topk(10, deadair_source_freshness_seconds)", "legendFormat": "{{source}}" }],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Volume z-score (same weekday/hour baseline)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "bottomk(10, deadair_source_volume_zscore)", "legendFormat": "{{source}}" }],
      "fieldConfig": {
        "defaults": {
          "custom": { "thresholdsStyle": { "mode": "line" } },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": -3 }] }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Blast radius: detections per source (top 10)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "topk(10, deadair_source_consumers)", "legendFormat": "{{source}}" }],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    }
  ]
}
